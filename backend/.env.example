# Application
APP_NAME=DocuMind AI
DEBUG=false
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-this

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/documind

# AI Provider - choose "openai" or "google"
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash

# API Keys (only fill in the one you use)
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Embedding Model (runs locally, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
